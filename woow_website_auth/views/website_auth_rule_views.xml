<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Tree View（列表）                                              -->
    <!-- ============================================================ -->
    <record id="woow_website_auth_rule_view_tree" model="ir.ui.view">
        <field name="name">woow.website.auth.rule.tree</field>
        <field name="model">woow.website.auth.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="page_type"/>
                <field name="path_prefix" column_invisible="True"/>
                <field name="website_page_id" column_invisible="True"/>
                <field name="display_path" string="路徑"/>
                <field name="auth_mode"/>
                <field name="group_id" optional="show"/>
                <field name="website_id" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Form View（表單）                                              -->
    <!-- ============================================================ -->
    <record id="woow_website_auth_rule_view_form" model="ir.ui.view">
        <field name="name">woow.website.auth.rule.form</field>
        <field name="model">woow.website.auth.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_button"
                               options='{"terminology": "archive"}'/>
                    </div>
                    <group>
                        <group string="基本設定">
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="website_id"/>
                        </group>
                        <group string="頁面設定">
                            <field name="page_type"/>
                            <field name="path_prefix"
                                   invisible="page_type != 'dynamic'"
                                   required="page_type == 'dynamic'"/>
                            <field name="website_page_id"
                                   invisible="page_type != 'static'"
                                   required="page_type == 'static'"/>
                        </group>
                    </group>
                    <group>
                        <group string="存取控制">
                            <field name="auth_mode"/>
                            <field name="group_id"
                                   invisible="auth_mode != 'group'"
                                   required="auth_mode == 'group'"/>
                            <field name="group_ids" widget="many2many_tags"
                                   invisible="auth_mode != 'multi_group'"
                                   required="auth_mode == 'multi_group'"/>
                        </group>
                        <group string="拒絕行為">
                            <field name="deny_action"/>
                            <field name="redirect_url"
                                   invisible="deny_action != 'redirect_custom'"
                                   required="deny_action == 'redirect_custom'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Search View（搜尋）                                            -->
    <!-- ============================================================ -->
    <record id="woow_website_auth_rule_view_search" model="ir.ui.view">
        <field name="name">woow.website.auth.rule.search</field>
        <field name="model">woow.website.auth.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="path_prefix"/>
                <field name="website_page_id"/>
                <field name="group_id"/>
                <field name="website_id"/>
                <separator/>
                <filter string="動態頁面" name="dynamic"
                        domain="[('page_type', '=', 'dynamic')]"/>
                <filter string="靜態頁面" name="static"
                        domain="[('page_type', '=', 'static')]"/>
                <separator/>
                <filter string="任何登入用戶" name="signed_in"
                        domain="[('auth_mode', '=', 'signed_in')]"/>
                <filter string="指定群組" name="group"
                        domain="[('auth_mode', '=', 'group')]"/>
                <filter string="多群組" name="multi_group"
                        domain="[('auth_mode', '=', 'multi_group')]"/>
                <separator/>
                <filter string="已封存" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="分組">
                    <filter string="頁面類型" name="group_page_type"
                            context="{'group_by': 'page_type'}"/>
                    <filter string="驗證模式" name="group_auth_mode"
                            context="{'group_by': 'auth_mode'}"/>
                    <filter string="網站" name="group_website"
                            context="{'group_by': 'website_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action                                                        -->
    <!-- ============================================================ -->
    <record id="woow_website_auth_rule_action" model="ir.actions.act_window">
        <field name="name">Auth Rules</field>
        <field name="res_model">woow.website.auth.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立第一條存取控制規則
            </p>
            <p>
                在這裡管理網站頁面的存取控制。您可以設定動態頁面（URL 前綴）或靜態頁面的權限規則。
            </p>
        </field>
    </record>

</odoo>
