<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- 會員模組分類 (Module Category)                                -->
        <!-- ============================================================ -->
        <record id="module_category_membership" model="ir.module.category">
            <field name="name">Membership</field>
            <field name="description">會員等級管理</field>
            <field name="sequence">30</field>
        </record>

        <!-- ============================================================ -->
        <!-- 會員等級 Groups（鏈式繼承）                                    -->
        <!-- Silver implies Portal, Gold implies Silver                    -->
        <!-- ============================================================ -->
        <record id="group_member_silver" model="res.groups">
            <field name="name">Silver Member</field>
            <field name="category_id" ref="module_category_membership"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
            <field name="comment">銀級會員，繼承 Portal 權限</field>
        </record>

        <record id="group_member_gold" model="res.groups">
            <field name="name">Gold Member</field>
            <field name="category_id" ref="module_category_membership"/>
            <field name="implied_ids" eval="[(4, ref('woow_website_auth.group_member_silver'))]"/>
            <field name="comment">金級會員，繼承 Silver 權限（自動包含 Portal）</field>
        </record>

    </data>
</odoo>
